import itertools
import time
import random

def generar_matriz_costos(n):
    """Genera una matriz simétrica de costos aleatorios entre nodos."""
    random.seed(42) # Semilla fija para que los resultados sean replicables
    matriz = [[0] * n for _ in range(n)]
    for i in range(n):
        for j in range(i + 1, n):
            costo = random.randint(10, 100)
            matriz[i][j] = costo
            matriz[j][i] = costo
    return matriz

def calcular_costo_ruta(ruta, matriz):
    """Calcula el costo total de una permutación específica regresando al origen."""
    total = 0
    for i in range(len(ruta) - 1):
        total += matriz[ruta[i]][ruta[i+1]]
    total += matriz[ruta[-1]][ruta[0]] # Regreso al nodo inicial
    return total

def optimizar_fuerza_bruta(nodos, matriz):
    """Evalúa todas las permutaciones posibles para hallar la ruta óptima."""
    mejor_ruta = None
    costo_minimo = float('inf')
    
    # Genera todas las permutaciones de los nodos
    for permutacion in itertools.permutations(nodos):
        costo_actual = calcular_costo_ruta(permutacion, matriz)
        if costo_actual < costo_minimo:
            costo_minimo = costo_actual
            mejor_ruta = permutacion
            
    return mejor_ruta, costo_minimo

# --- EXPERIMENTO PRINCIPAL ---
if __name__ == "__main__":
    print("=== SIMULADOR DE OPTIMIZACIÓN DE RUTAS (FUERZA BRUTA) ===")
    print("Nodos | Permutaciones | Tiempo de Ejecución")
    print("-" * 45)
    
    # Evaluación incremental desde 4 hasta 11 nodos para demostrar la explosión combinatoria
    for n in range(4, 12):
        nodos = list(range(n))
        matriz = generar_matriz_costos(n)
        
        # Medición del tiempo de CPU
        inicio = time.perf_counter()
        ruta, costo = optimizar_fuerza_bruta(nodos, matriz)
        fin = time.perf_counter()
        
        tiempo_ms = (fin - inicio) * 1000
        total_permutaciones = round(time.perf_counter() - inicio) # Simulación de conteo factorial n!
        import math
        permutaciones_reales = math.factorial(n)
        
        print(f"{n:5d} | {permutaciones_reales:13,d} | {tiempo_ms:15.4f} ms")
